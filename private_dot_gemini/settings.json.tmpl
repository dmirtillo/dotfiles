{
  "security": {
    "auth": {
      "selectedType": "vertex-ai"{{- if .gcloud_project }},
      "enterpriseGcpProjectId": "{{ .gcloud_project }}"{{- end }}
    }
  }{{- if .gcloud_project }},
  "enterpriseGcpProjectId": "{{ .gcloud_project }}",
  "billing": {
    "vertexAi": {
      "projectId": "{{ .gcloud_project }}",
      "location": "{{ .gcloud_location }}"
    }
  },
  "projectId": "{{ .gcloud_project }}",
  "location": "{{ .gcloud_location }}",
  "gcpRegion": "{{ .gcloud_location }}"{{- end }},
  "mcpServers": {
    "gcp-cost": {
      "command": "/opt/homebrew/bin/gcp-cost-mcp-server",
      "env": {
        "GOOGLE_CLOUD_PROJECT": "{{ .gcloud_project }}"
      }
    }{{- if .aws_profile }},
    "aws-pricing": {
      "command": "/opt/homebrew/bin/uvx",
      "env": {
        "AWS_PROFILE": "{{ .aws_profile }}",
        "AWS_REGION": "us-east-1",
        "HOME": "{{ .chezmoi.homeDir }}",
        "AWS_SHARED_CREDENTIALS_FILE": "{{ .chezmoi.homeDir }}/.aws/credentials"
      },
      "args": [
        "awslabs.aws-pricing-mcp-server"
      ]
    }
    {{- end }}
  }
}
