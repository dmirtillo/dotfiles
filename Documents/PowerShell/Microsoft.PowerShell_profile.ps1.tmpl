# Create and enter directory
function mkcd {
    param([Parameter(Mandatory=$true)][string]$Path)
    New-Item -ItemType Directory -Force -Path $Path | Out-Null
    Set-Location $Path
}

# Extract various archive formats (simplified for Windows)
function extract {
    param([Parameter(Mandatory=$true)][string]$Path)
    if (Test-Path $Path) {
        if ($Path -match '\.zip$') { Expand-Archive -Path $Path -DestinationPath . }
        elseif ($Path -match '\.tar\.gz$|\.tgz$|\.tar$') { tar xf $Path }
        else { Write-Host "Format not supported by extract function natively in PowerShell. Use 7z manually." }
    } else {
        Write-Host "'$Path' is not a valid file"
    }
}

# Find files and directories (using fd)
function findfile { fd --type f @args }
function finddir { fd --type d @args }

# Weather function
function weather {
    param([string]$Location = "Rome")
    $url = "wttr.in/$Location"
    # Invoke-RestMethod parses, so curl.exe is better for terminal output here
    curl.exe $url
}

# Quick backup function
function backup {
    param([Parameter(Mandatory=$true)][string]$Path)
    $DateStr = Get-Date -Format "yyyyMMdd_HHmmss"
    Copy-Item -Path $Path -Destination "$Path.backup.$DateStr"
}

# Git clone and cd
function gclone {
    param([Parameter(Mandatory=$true)][string]$Url)
    git clone $Url
    $DirName = ($Url -split '/')[-1] -replace '\.git$',''
    Set-Location $DirName
}

