{{- if eq .chezmoi.os "darwin" -}}
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.litellm.proxy</string>

  <key>ProgramArguments</key>
  <array>
    <string>{{ .chezmoi.homeDir }}/.local/pipx/venvs/litellm/bin/litellm</string>
    <string>--config</string>
    <string>{{ .chezmoi.homeDir }}/.config/litellm/config.yaml</string>
    <string>--port</string>
    <string>4000</string>
  </array>

  <key>EnvironmentVariables</key>
  <dict>
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:{{ .chezmoi.homeDir }}/.local/bin</string>
    <key>HOME</key>
    <string>{{ .chezmoi.homeDir }}</string>
  </dict>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <dict>
    <key>SuccessfulExit</key>
    <false/>
  </dict>

  <key>ThrottleInterval</key>
  <integer>10</integer>

  <key>StandardOutPath</key>
  <string>{{ .chezmoi.homeDir }}/.local/share/litellm/proxy.log</string>

  <key>StandardErrorPath</key>
  <string>{{ .chezmoi.homeDir }}/.local/share/litellm/proxy.err</string>

  <key>WorkingDirectory</key>
  <string>{{ .chezmoi.homeDir }}</string>
</dict>
</plist>
{{- end -}}
