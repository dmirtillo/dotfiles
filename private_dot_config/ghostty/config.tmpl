# =============================================================================
# GHOSTTY CHEAT SHEET & CONFIGURATION
# =============================================================================
# RELATED DOCS:
# - Tmux: ~/.tmux.conf
# - TmuxAI: ~/.config/tmuxai/config.yaml
#
# WINDOW MANAGEMENT:
# - Cmd+Shift+N : New Window
# - Cmd+Shift+T : New Tab
# - Cmd+W       : Close Window/Tab
#
# NOTE: Ghostty is configured to automatically start `tmux`.
# You should use tmux for all splits and tabs so that TmuxAI can see them!
#
# FONT SIZING:
# - Cmd+=       : Increase Font Size
# - Cmd+-       : Decrease Font Size
# - Cmd+0       : Reset Font Size
# =============================================================================

theme = TokyoNight
font-family = "MesloLGS NF"
font-size = 11
window-padding-x = 10
window-padding-y = 10
window-theme = ghostty
macos-titlebar-style = hidden

# Automatically start or attach to the 'main' tmux session on every Ghostty launch.
# This ensures we always have our multiplexer and TmuxAI available natively.
#
# WHY ABSOLUTE PATH:
#   Ghostty spawns its initial shell with `bash --noprofile --norc`, which means
#   ~/.zshrc is never sourced and PATH does not include Homebrew (/opt/homebrew/bin)
#   or the system bin. Using the platform-specific absolute path avoids a "command
#   not found: tmux" error at startup.
#
#   darwin  → /opt/homebrew/bin/tmux  (Apple Silicon Homebrew prefix)
#   linux   → /usr/bin/tmux           (pacman-installed tmux)
#   other   → tmux                    (fallback, assumes tmux is on PATH)
{{ if eq .chezmoi.os "darwin" -}}
command = /opt/homebrew/bin/tmux new-session -A -s main
{{- else if eq .chezmoi.os "linux" -}}
command = /usr/bin/tmux new-session -A -s main
{{- else -}}
command = tmux new-session -A -s main
{{- end }}