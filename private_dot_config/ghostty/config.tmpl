# =============================================================================
# GHOSTTY CHEAT SHEET & CONFIGURATION
# =============================================================================
# RELATED DOCS:
# - Tmux: ~/.tmux.conf
# - TmuxAI: ~/.config/tmuxai/config.yaml
#
# WINDOW MANAGEMENT:
# - Cmd+Shift+N : New Window
# - Cmd+Shift+T : New Tab
# - Cmd+W       : Close Window/Tab
#
# NOTE: Ghostty is configured to automatically start `tmux`.
# You should use tmux for all splits and tabs so that TmuxAI can see them!
#
# FONT SIZING:
# - Cmd+=       : Increase Font Size
# - Cmd+-       : Decrease Font Size
# - Cmd+0       : Reset Font Size
# =============================================================================

theme = TokyoNight
font-family = "MesloLGS NF"
font-size = 11
window-padding-x = 10
window-padding-y = 10
window-theme = ghostty
macos-titlebar-style = hidden

# Automatically start or attach to the 'main' tmux session
# This ensures we always have our multiplexer and TmuxAI available natively.
# Use absolute path to avoid PATH issues when Ghostty launches bash with --noprofile --norc
{{ if eq .chezmoi.os "darwin" -}}
command = /opt/homebrew/bin/tmux new-session -A -s main
{{- else if eq .chezmoi.os "linux" -}}
command = /usr/bin/tmux new-session -A -s main
{{- else -}}
command = tmux new-session -A -s main
{{- end }}