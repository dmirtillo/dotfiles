{{- if eq .chezmoi.os "windows" -}}
# =============================================================================
# PowerShell Profile (Windows Parity with Zsh)
# Mapped to ~/Documents/PowerShell/Microsoft.PowerShell_profile.ps1 via chezmoi
# =============================================================================

# Require RemoteSigned for scripts
if ((Get-ExecutionPolicy) -ne 'RemoteSigned' -and (Get-ExecutionPolicy) -ne 'Unrestricted') {
    Write-Warning "Execution Policy is $((Get-ExecutionPolicy)). Some scripts may not run. Recommend: Set-ExecutionPolicy RemoteSigned -Scope CurrentUser"
}

# ============================================================================
# MODERN TOOL INTEGRATIONS
# ============================================================================

# zoxide: smarter cd
if (Get-Command zoxide -ErrorAction SilentlyContinue) {
    Invoke-Expression (& { (zoxide init powershell | Out-String) })
    Set-Alias -Name cd -Value z -Option AllScope
    Set-Alias -Name cdi -Value zi -Option AllScope
}

# mise: fast dev toolchain manager
if (Get-Command mise -ErrorAction SilentlyContinue) {
    Invoke-Expression (& { (mise activate powershell | Out-String) })
}

# oh-my-posh: fast prompt (emulates Powerlevel10k on Windows)
if (Get-Command oh-my-posh -ErrorAction SilentlyContinue) {
    # Using a built-in theme that looks like p10k. 
    # You can customize this later to a specific JSON file.
    oh-my-posh init pwsh --config "$env:POSH_THEMES_PATH\jandedobbeleer.omp.json" | Invoke-Expression
}

# ============================================================================
# PRODUCTIVITY ALIASES AND FUNCTIONS (matching Zsh)
# ============================================================================

# File and Directory Navigation
function .. { Set-Location .. }
function ... { Set-Location ..\.. }
function .... { Set-Location ..\..\.. }
function ~ { Set-Location ~ }

# Enhanced ls commands (using eza if available)
if (Get-Command eza -ErrorAction SilentlyContinue) {
    Set-Alias ls eza
    function ll { eza -alF --icons --git $args }
    function la { eza -a --icons $args }
    function l { eza -F --icons $args }
    function lt { eza -l --sort=modified $args }
    function lh { eza -l --icons $args }
    function lsize { eza -l --sort=size $args }
    function ltree { eza --tree --level=2 --icons $args }
}

# Git Enhancements
function gst { git status $args }
function gco { git checkout $args }
function gcb { git checkout -b $args }
function gp { git push $args }
function gpl { git pull $args }
function gf { git fetch $args }
function gm { git merge $args }
function gr { git rebase $args }
function glog { git log --oneline --graph --decorate $args }
function gb { git branch $args }

# System Utilities
function myip { Invoke-RestMethod -Uri "https://ipinfo.io/ip" }

# File operations with safety (built-in to PowerShell, just aliasing for muscle memory)
Set-Alias grep findstr

# bat: syntax-highlighted cat replacement
if (Get-Command bat -ErrorAction SilentlyContinue) {
    Set-Alias cat bat
}

# Quick access to common directories
function desktop { Set-Location "$env:USERPROFILE\Desktop" }
function downloads { Set-Location "$env:USERPROFILE\Downloads" }
function documents { Set-Location "$env:USERPROFILE\Documents" }

# Create and enter directory
function mkcd {
    param([string]$path)
    New-Item -ItemType Directory -Force -Path $path | Out-Null
    Set-Location $path
}

# === Agent CLI Wrappers ===
# Office read/write hybrid loop using officecli and markitdown

function office-read {
    param([string]$file)
    if ([string]::IsNullOrEmpty($file)) {
        Write-Host "Usage: office-read <file>"
        return
    }
    # Explicitly flush resident mode changes to disk before reading
    & officecli close $file 2>$null
    # Multimodal OCR is omitted by default for performance
    & uv run --prerelease=allow --with 'markitdown[all]==0.1.6' markitdown $file
}

function office-write {
    param([string]$file, [string]$find_str, [string]$replace_str)
    if ([string]::IsNullOrEmpty($file) -or [string]::IsNullOrEmpty($find_str) -or [string]::IsNullOrEmpty($replace_str)) {
        Write-Host "Usage: office-write <file> <find> <replace>"
        return
    }
    # Execute writes globally using text replacement
    & officecli set $file / --find $find_str --replace $replace_str
    $exitCode = $LASTEXITCODE
    # Sequentially flush to prevent zip corruption
    & officecli close $file 2>$null
    return $exitCode
}

function office-query {
    param([string]$file, [string]$text)
    if ([string]::IsNullOrEmpty($file) -or [string]::IsNullOrEmpty($text)) {
        Write-Host "Usage: office-query <file> <text>"
        return
    }
    & officecli close $file 2>$null
    $jsonOutput = & officecli query $file ":contains(`"$text`")" --json | Out-String
    $queryResult = $jsonOutput | ConvertFrom-Json
    if ($queryResult.data.results) {
        foreach ($result in $queryResult.data.results) {
            Write-Output "Match: $($result.text)"
            Write-Output "Path: $($result.path)"
            Write-Output "Type: $($result.type)"
            Write-Output "---"
        }
    }
}

function office-format {
    param([string]$file, [string]$text)
    
    $props = $args
    if ([string]::IsNullOrEmpty($file) -or [string]::IsNullOrEmpty($text) -or $props.Count -eq 0) {
        Write-Error "Usage: office-format <file> <text> <property> [value]..."
        return 1
    }
    
    $valid_props = @("text", "style", "alignment", "bold", "italic", "font", "size", "color", "spaceBefore", "spaceAfter", "spaceBeforeLines", "spaceAfterLines", "lineSpacing", "indent", "liststyle", "formula", "direction", "bidi", "fill", "background", "x", "y", "w", "h", "width", "height")
    
    $i = 0
    while ($i -lt $props.Count) {
        $arg = $props[$i]
        $key = ""
        
        if ($arg -eq "--prop") {
            if ($i + 1 -ge $props.Count) {
                Write-Error "Error: Missing value for --prop"
                return 1
            }
            $next_arg = $props[$i+1]
            $key = $next_arg.Split('=')[0]
            $i += 2
        } elseif ($arg.StartsWith("--prop=")) {
            $key_val = $arg.Substring(7)
            $key = $key_val.Split('=')[0]
            $i += 1
        } else {
            $i += 1
            continue
        }
        
        $is_valid = $false
        foreach ($valid_prop in $valid_props) {
            if ($key -eq $valid_prop -or $key.StartsWith("font.") -or $key.StartsWith("underline.") -or $key.StartsWith("anchor.")) {
                $is_valid = $true
                break
            }
        }
        
        if (-not $is_valid) {
            Write-Error "Error: Invalid formatting property '$key'"
            return 1
        }
    }
    
    & officecli close $file 2>$null
    
    $jsonOutput = & officecli query $file ":contains(`"$text`")" --json | Out-String
    try {
        $queryResult = $jsonOutput | ConvertFrom-Json
        # Handle single vs multiple results from ConvertFrom-Json
        if ($queryResult.data.results -is [array]) {
            $paths = $queryResult.data.results.path
        } elseif ($queryResult.data.results) {
            $paths = @($queryResult.data.results.path)
        } else {
            $paths = $null
        }
    } catch {
        $paths = $null
    }
    
    if (-not $paths -or $paths.Count -eq 0) {
        Write-Error "Error: Text not found in document"
        return 1
    }
    
    $status = 0
    foreach ($path in $paths) {
        if (-not [string]::IsNullOrEmpty($path)) {
            & officecli set $file $path @props
            if ($LASTEXITCODE -ne 0) {
                $status = $LASTEXITCODE
            }
        }
    }
    
    & officecli close $file 2>$null
    return $status
}

{{- end -}}