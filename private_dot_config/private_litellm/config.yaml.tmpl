# =============================================================================
# LiteLLM Proxy Configuration
# Deployed to ~/.config/litellm/config.yaml by chezmoi
#
# PURPOSE:
#   Acts as a local OpenAI-compatible proxy exclusively for Anthropic Claude
#   models via Vertex AI. Runs on http://localhost:4000.
#
# ROUTING:
#   - claude-*  →  Vertex AI (gcloud ADC, no API key needed)
#   - gemini-*  →  Google AI Studio (kept for potential direct use / tmuxai)
#
# NO DATABASE:
#   Runs completely DB-free (no PostgreSQL). master_key is null so the proxy
#   accepts all requests without authentication — safe because it only listens
#   on localhost (macOS LaunchAgent binds to 127.0.0.1 by default).
#   The /ui endpoint is available but shows login errors without a DB; use
#   `tail -f ~/.local/share/litellm/proxy.log` to monitor live traffic instead.
#
# OPENCODE:
#   OpenCode routes Gemini models DIRECTLY to Google AI Studio via @ai-sdk/google
#   (not through this proxy) to avoid agent loop issues with the LiteLLM
#   OpenAI-compatible translation layer. Only Claude models go through LiteLLM.
#
# LOGS:
#   stdout → ~/.local/share/litellm/proxy.log
#   stderr → ~/.local/share/litellm/proxy.err
# =============================================================================

model_list:
  # --- Gemini models (via Google AI Studio) ---
  - model_name: gemini-3.1-pro-preview
    litellm_params:
      model: gemini/gemini-3.1-pro-preview
      api_key: "{{ .gemini_api_key }}"

  - model_name: gemini-3.1-flash-preview
    litellm_params:
      model: gemini/gemini-3.1-flash-lite-preview
      api_key: "{{ .gemini_api_key }}"

  # --- Anthropic models (via Vertex AI, us-east5) ---
  - model_name: claude-sonnet-4-6
    litellm_params:
      model: vertex_ai/claude-sonnet-4-6
      vertex_project: "{{ .gcloud_project }}"
      vertex_location: "us-east5"

  - model_name: claude-opus-4-7
    litellm_params:
      model: vertex_ai/claude-opus-4-7@default
      vertex_project: "{{ .gcloud_project }}"
      vertex_location: "us-east5"

  - model_name: claude-sonnet-4
    litellm_params:
      model: vertex_ai/claude-sonnet-4
      vertex_project: "{{ .gcloud_project }}"
      vertex_location: "us-east5"

  - model_name: claude-opus-4
    litellm_params:
      model: vertex_ai/claude-opus-4
      vertex_project: "{{ .gcloud_project }}"
      vertex_location: "us-east5"

general_settings:
  master_key: null

litellm_settings:
  modify_params: true
