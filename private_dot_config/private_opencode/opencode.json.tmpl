{
  // ============================================================================
  // OpenCode Configuration
  // Deployed to ~/.config/opencode/opencode.json by chezmoi (as .tmpl)
  //
  // MODEL ROUTING:
  //   Gemini models  →  google/ provider (@ai-sdk/google, direct Google AI Studio)
  //   Claude models  →  litellm/ provider (@ai-sdk/openai-compatible, localhost:4000)
  // ============================================================================
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-3.1-pro-preview",
  "small_model": "google/gemini-3.1-flash-lite-preview",
  "provider": {
    "google": {
      "npm": "@ai-sdk/google",
      "name": "Google AI Studio",
      "options": {
        "apiKey": "{{ .gemini_api_key }}"
      },
      "models": {
        "gemini-3.1-pro-preview": {
          "name": "Gemini 3.1 Pro"
        },
        "gemini-3.1-flash-lite-preview": {
          "name": "Gemini 3.1 Flash Lite"
        }
      }
    },
    "litellm": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "LiteLLM (Vertex Proxy)",
      "options": {
        "baseURL": "http://localhost:4000/v1"
      },
      "models": {
        "claude-sonnet-4-6": {
          "name": "Claude Sonnet 4.6 (Vertex)"
        },
        "claude-opus-4-7": {
          "name": "Claude Opus 4.7 (Vertex)"
        },
        "claude-sonnet-4": {
          "name": "Claude Sonnet 4 (Vertex)"
        },
        "claude-opus-4": {
          "name": "Claude Opus 4 (Vertex)"
        }
      }
    }
  },
  "permission": {
    "mcp_*": "ask"
  },
  "mcp": {
    "gcp-cost": {
      "type": "local",
      "command": ["/opt/homebrew/bin/gcp-cost-mcp-server"]
    }{{- if .aws_profile }},
    "aws-pricing": {
      "type": "local",
      "command": [
        "/usr/bin/env",
        "AWS_PROFILE={{ .aws_profile }}",
        "AWS_REGION=us-east-1",
        "HOME={{ .chezmoi.homeDir }}",
        "AWS_SHARED_CREDENTIALS_FILE={{ .chezmoi.homeDir }}/.aws/credentials",
        "/opt/homebrew/bin/uvx",
        "awslabs.aws-pricing-mcp-server@latest"
      ],
      "env": {
        "AWS_PROFILE": "{{ .aws_profile }}",
        "AWS_REGION": "us-east-1",
        "HOME": "{{ .chezmoi.homeDir }}",
        "AWS_SHARED_CREDENTIALS_FILE": "{{ .chezmoi.homeDir }}/.aws/credentials"
      }
    }
    {{- end }}
  }
}
