# =============================================================================
# TMUXAI CHEAT SHEET & CONFIGURATION
# =============================================================================
# RELATED DOCS:
# - Ghostty: ~/.config/ghostty/config
# - Tmux: ~/.tmux.conf
#
# WHAT IT IS:
# TmuxAI is an AI assistant that lives in your tmux session. It can read
# everything currently visible in your other tmux panes automatically.
#
# CORE COMMANDS (Type these in the TmuxAI chat pane):
# - /model                 : List available models and switch between them.
# - /model <name>          : Switch to a specific model (e.g., /model gemini-pro).
# - /clear                 : Clear the current chat history.
# - /reset                 : Clear history and reset all panes.
# - /info                  : Show system info and context statistics.
#
# KEYBOARD SHORTCUTS:
# - Ctrl+O                 : Open current prompt in an external editor (Vim).
#                            Useful for writing multi-line prompts.
# - Alt+E                  : Alternative for multiline editor.
#
# OBSERVE MODE:
# By default, TmuxAI is in observe mode. It watches the execution of commands
# in your Exec Pane and waits for them to finish before reading the output.
# =============================================================================

default_model: "gemini-fast"

# MODEL NOTES:
#   gemini provider:    native Google AI SDK, bare model names (no "google/" prefix)
#                       Valid model IDs: https://ai.google.dev/gemini-api/docs/models
#   openrouter provider: OpenAI-compatible chat completions — override base_url to point
#                       at local LiteLLM proxy (localhost:4000) instead of openrouter.ai
#                       LiteLLM then forwards to Vertex AI using gcloud ADC (no API key)
models:
  gemini-fast:
    provider: "gemini"
    model: "gemini-3.1-flash-lite-preview"
    api_key: "{{ .gemini_api_key }}"

  gemini-pro:
    provider: "gemini"
    model: "gemini-3.1-pro-preview"
    api_key: "{{ .gemini_api_key }}"

  claude-sonnet:
    provider: "openrouter"
    model: "claude-sonnet-4-6"
    api_key: "noop"
    base_url: "http://localhost:4000/v1"
    # Routes via local LiteLLM proxy → Vertex AI (gcloud ADC, no real API key needed)