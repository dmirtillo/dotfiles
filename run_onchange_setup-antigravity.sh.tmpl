#!/usr/bin/env bash
set -euo pipefail

# =============================================================================
# Set up Antigravity CLI configuration and skills
# chezmoi:template:hash {{ include "private_dot_gemini/antigravity-cli/settings.json.tmpl" | sha256sum }}
# =============================================================================

echo "[antigravity] Setting up skills..."

if command -v npx &>/dev/null; then
  echo "  Installing GSD Core for Antigravity (agy)..."
  npx --yes @opengsd/gsd-core@latest --antigravity --global
  echo "  Installing GSD Core for Gemini CLI..."
  npx --yes @opengsd/gsd-core@latest --kimi --global
else
  echo "  WARNING: npm not found. Install Node.js to use @opengsd/gsd-core."
fi

if command -v agy &>/dev/null; then
  agy plugin install https://github.com/DietrichGebert/ponytail
fi

echo "  Done."
