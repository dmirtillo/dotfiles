[user]
	name = {{ .git_name }}
	email = {{ .git_email }}
{{ if eq .chezmoi.os "darwin" -}}
[credential]
	helper = osxkeychain
{{ else if eq .chezmoi.os "linux" -}}
[credential]
	helper = cache --timeout=86400
{{ else -}}
[credential]
	helper = store
{{ end -}}
[core]
	editor = vim
[init]
	defaultBranch = main

# Work email overrides -- add these locally per-repo or use includeIf:
# git config --local user.email "your.work@email.com"
#
# Or add conditional includes to your global ~/.gitconfig:
# [includeIf "gitdir:~/projects/work/"]
#     path = ~/.gitconfig-work
